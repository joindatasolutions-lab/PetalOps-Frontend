{
  "name": "flora-v2-domicilios",
  "private": true,
  "version": "1.0.0",
  "description": "Panel de domicilios con pruebas unitarias",
  "scripts": {
    "test": "node --test tests/*.test.js",
    "test:unit": "node --test tests/*.test.js",
    "test:integration": "node --test tests/*.integration.test.js",
    "coverage": "c8 --reporter=text --reporter=html --reporter=lcov node --test tests/*.test.js",
    "coverage:check": "c8 --check-coverage --lines 75 --functions 75 --branches 65 --statements 75 node --test tests/*.test.js"
  },
  "devDependencies": {
    "c8": "^10.1.3"
  },
  "c8": {
    "all": true,
    "include": [
      "app/**/*.js"
    ],
    "exclude": [
      "tests/**/*.js"
    ],
    "report-dir": "coverage"
  }
}
